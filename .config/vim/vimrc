function! NetrwRecursiveExpand()
    " Ensure we are on a directory line
    let l:line = getline('.')
    if l:line !~ '/$'
        return
    endif

    " Capture the indentation of the starting directory
    " (netrw uses '| ' or '│ ' for tree levels)
    let l:base_indent = matchstr(l:line, '^[| │]*')
    let l:base_len = strlen(l:base_indent)

    " Expand the current directory
    execute "normal \<CR>"

    " Iterate through subsequent lines to find subdirectories
    let l:curr = line('.') + 1
    while l:curr <= line('$')
        let l:line_content = getline(l:curr)
        let l:indent = matchstr(l:line_content, '^[| │]*')

        " Stop if we encounter a line with the same or less indentation
        if strlen(l:indent) <= l:base_len && l:line_content !~ '^$'
            break
        endif

        " If the line is a directory, expand it
        if l:line_content =~ '/$'
            call cursor(l:curr, 1)
            execute "normal \<CR>"
        endif
        let l:curr += 1
    endwhile
endfunction

function! NetrwRecursiveCollapse()
    let l:line_num = line('.')
    let l:line_content = getline(l:line_num)

    " Proceed only if the cursor is on a directory
    if l:line_content !~ '/$'
        return
    endif

    " Determine the indentation level of the parent directory
    let l:base_indent = matchstr(l:line_content, '^[| │]*')
    let l:base_len = strlen(l:base_indent)

    " Find the boundaries of the sub-tree
    let l:last_line = l:line_num
    let l:max_line = line('$')
    while l:last_line < l:max_line
        let l:next_content = getline(l:last_line + 1)
        let l:next_indent = matchstr(l:next_content, '^[| │]*')
        if strlen(l:next_indent) <= l:base_len && l:next_content !~ '^$'
            break
        endif
        let l:last_line += 1
    endwhile

    " Exit if there are no expanded children
    if l:last_line == l:line_num
        return
    endif

    " Iterate backwards from the bottom to the top of the sub-tree.
    " This prevents line-index shifts from affecting the loop.
    let l:i = l:last_line
    while l:i > l:line_num
        let l:curr_content = getline(l:i)
        if l:curr_content =~ '/$'
            let l:curr_indent = matchstr(l:curr_content, '^[| │]*')
            let l:next_content = getline(l:i + 1)
            let l:next_indent = matchstr(l:next_content, '^[| │]*')

            " If the next line is more indented, the directory is open; close it.
            if strlen(l:next_indent) > strlen(l:curr_indent)
                call cursor(l:i, 1)
                execute "normal \<CR>"
            endif
        endif
        let l:i -= 1
    endwhile

    " Restore cursor to the original parent directory
    call cursor(l:line_num, 1)
endfunction

augroup NetrwCustom
    autocmd!
    " Map 'K' to recursive expand inside netrw buffers
    autocmd FileType netrw nnoremap <buffer> K :call NetrwRecursiveExpand()<CR>
augroup END

augroup NetrwCollapseCustom
    autocmd!
    autocmd FileType netrw nnoremap <buffer> zC :call NetrwRecursiveCollapse()<CR>
augroup END
